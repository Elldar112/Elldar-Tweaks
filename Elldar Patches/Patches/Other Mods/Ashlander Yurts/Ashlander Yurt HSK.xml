<?xml version="1.0" encoding="UTF-8"?>
<Patch>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Morrowrim Ashlander Yurts</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>

		<li Class="PatchOperationFindMod">
		<mods>
			<li>Tec's Assorted Patches</li> <!-- Add to subcategory Camping Gear - Requires Tec's Patches for Camping Tent -->
		</mods>
		<match Class="PatchOperationInsert">
			<xpath>Defs/ArchitectSense.DesignationSubCategoryDef[defName="SubCategory_CampingTent"]/defNames/li[8]</xpath>
			<value>
				<li>AshlandYurt</li>
			</value>
		</match>
		</li>

        <li Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[defName = "AshlandYurt"]/costList</xpath>
          <value>
            <costList>
              <WoodPlank>120</WoodPlank>
            </costList>
          </value>
        </li>

        <li Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="AshlandYurt"]/researchPrerequisites</xpath>
          <match Class="PatchOperationReplace">
            <xpath>Defs/ThingDef[defName="AshlandYurt"]/researchPrerequisites</xpath>
            <value>
              <researchPrerequisites>
                <li>Beds_B1</li>
              </researchPrerequisites>
            </value>
          </match>
          <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="AshlandYurt"]</xpath>
            <value>
              <researchPrerequisites>
                <li>Beds_B1</li>
              </researchPrerequisites>
            </value>
          </nomatch>
        </li>

        <li Class="PatchOperationReplace">
          <xpath>Defs/ThoughtDef[defName = "Yurtbuff"]/stages/li[1]/baseMoodEffect</xpath>
          <value>
            <baseMoodEffect>2</baseMoodEffect>
          </value>
        </li>

      </operations>
    </match>
  </Operation>

</Patch>
