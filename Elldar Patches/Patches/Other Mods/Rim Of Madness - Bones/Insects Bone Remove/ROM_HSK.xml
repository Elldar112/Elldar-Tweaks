<?xml version="1.0" encoding="utf-8" ?>
<Patch>
	<Operation Class="PatchOperationFindMod">
		<mods>
			<li>Rim of Madness - Bones</li>
		</mods>
		
		<match Class="PatchOperationFindMod">
			<mods>
				<li>Core SK</li>
			</mods>
			
			<match Class="PatchOperationSequence">
				<operations>
				
					<!-- =====[Bases]===== -->
					<li Class="PatchOperationAdd">
						<xpath>Defs/ThingDef[@Name="FishThingBase"]/statBases</xpath>
						<value>
							<BoneAmount>0</BoneAmount>
						</value>
					</li>
					
					<li Class="PatchOperationAdd">
						<xpath>Defs/ThingDef[@Name="SK_InsectThingBase"]/statBases</xpath>
						<value>
							<BoneAmount>0</BoneAmount>
						</value>
					</li>
					
				</operations>
			</match>
		</match>
	</Operation>
</Patch>