<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>More animal beds</li>
    </mods>
    <match Class="PatchOperationSequence">
		<operations>
	  
		<!-- Architect Sense -->
			<li Class="PatchOperationAdd">
			  <xpath>Defs/ArchitectSense.DesignationSubCategoryDef[defName="SubCategory_AnimalFurniture"]/defNames</xpath>
			  <value>
			  	<li>GSAnimalBedBig</li>
				<li>GSAnimalBedBigPrestige</li>
			  </value>
			</li>

		<!-- Research -->
			<li Class="PatchOperationAdd">
			  <xpath>Defs/ThingDef[defName="GSAnimalBedBig" or defName="GSAnimalBedBigPrestige"]</xpath>
			  <value>
			  	<researchPrerequisites>
					<li>Animal_C1</li>
				</researchPrerequisites>
			  </value>
			</li>
		
		</operations>
    </match>
  </Operation>

</Patch>
