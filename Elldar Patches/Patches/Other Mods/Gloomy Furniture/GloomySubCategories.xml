<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>GloomyFurniture</li>
      <li>GloomyFurniture (Continued)</li>
    </mods>

    <match Class="PatchOperationSequence">
      <operations>

        <li Class="PatchOperationAdd">
          <xpath>Defs</xpath>
          <value>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyBoundaryDeco</defName>
              <label>Boundary Stones</label>
              <description>Beautiful little additions</description>
              <defNames>
                <li>GL_BoundaryWood</li>
                <li>GL_BoundaryStone</li>
                <li>GL_BoundaryWoodCorner</li>
                <li>GL_BoundaryStoneCorner</li>
              </defNames>
              <designationCategory>Structure</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyFireplaces</defName>
              <label>Classic Fireplaces</label>
              <description>Comfy main hall gather point.</description>
              <defNames>
                <li>RGK_Fireplace</li>
                <li>RGK_FireplaceE</li>
              </defNames>
              <designationCategory>Temperature</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyRugs</defName>
              <label>Classic Rugs</label>
              <description>I don't want to wake up with stone under my feet anymore!</description>
              <defNames>
                <li>RugA_Small</li>
                <li>RugB_Small</li>
                <li>RugC_Small</li>
                <li>RugA</li>
                <li>RugB</li>
                <li>RugC</li>
                <li>RugA_Large</li>
                <li>RugB_Large</li>
                <li>RugC_Large</li>
              </defNames>
              <designationCategory>Accessories</designationCategory>
              <debug>false</debug>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyLamps</defName>
              <label>Street Lamps</label>
              <description>Fancy</description>
              <defNames>
                <li>RGK_Street_Lamp_L</li>
                <li>RGK_Street_Lamp</li>
                <li>RGK_Street_Lamp_Seven</li>
                <li>RGK_Street_Lamp_SevenE</li>
              </defNames>
              <designationCategory>Accessories</designationCategory>
              <debug>false</debug>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyJoyTables</defName>
              <label>Game Tables</label>
              <description>Billiard and poker.</description>
              <defNames>
                <li>BilliardsTable</li>
				<li>PokerTable</li>
                <li>GL_BilliardsTable</li>
                <li>GL_PokerTable</li>
              </defNames>
              <designationCategory>Joy</designationCategory>
              <debug>false</debug>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyStorage</defName>
              <label>Classic Storage</label>
              <description>Chests and boxes</description>
              <defNames>
			    <li>GL_Locker</li>
                <li>GloomyDeco_Box</li>
                <li>RGK_Manger</li>
                <li>GL_Shelf</li>
                <li>RKGWineRackB</li>
              </defNames>
              <designationCategory>LWM_DS_Storage</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyBedroomDeco</defName>
              <label>Classic Bedroom Furniture</label>
              <description>Wardrobes, end tables and dressers</description>
              <defNames>
                <li>WardrobeA</li>
                <li>WardrobeB</li>
				<li>GL_Bookshelf</li>
				<li>RGK_Dresser</li>
				<li>RGK_EndTable</li>
				<li>RGK_EndTableWithLamp</li>
				<li>RGK_EndTableWithLampE</li>
              </defNames>
              <designationCategory>Furniture</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

			<ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyKitchen</defName>
              <label>Classic Kitchen Accessories</label>
              <description>Cupboards, kitchen shelves and drawers</description>
              <defNames>
                <li>GL_Cupboard</li>
                <li>GL_TablewareShelf</li>
				<li>SM_ButcherShelf</li>
				<li>SM_KitchenCupboard_A</li>
				<li>SM_KitchenCupboard_B</li>
				<li>SM_KitchenCupboard_C</li>
				<li>SM_Sink</li>
				<li>SM_CornerIRD</li>
              </defNames>
              <designationCategory>Furniture</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyTables</defName>
              <label>Classic Tables</label>
              <description>Metal tables? Why?</description>
              <defNames>
                <li>RGK_TableA</li>
                <li>RGK_TableC</li>
                <li>RGK_TableB</li>
                <li>RGK_TableD</li>
                <li>RGK_TableE</li>
                <li>RGK_TableF</li>
                <li>RGK_TableG</li>
                <li>RGK_TableH</li>
                <li>RGK_MiniTableA</li>
                <li>RGK_MiniTableB</li>
              </defNames>
              <designationCategory>Furniture</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

            <ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyChairs</defName>
              <label>Classic Chairs</label>
              <description>I want nice looking stools!</description>
              <defNames>
                <li>RGK_SimpleChair</li>
                <li>RGK_Chair</li>
                <li>RGKDiningChair</li>
                <li>GL_Bench</li>
              </defNames>
              <designationCategory>Furniture</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

			<ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyDecor</defName>
              <label>Classic Decor</label>
              <description>Flowers, tea cups boards and other decorations</description>
              <defNames>
                <li>RGK_bucketr</li>
                <li>RGK_orc</li>
				<li>RGK_Flower</li>
                <li>RGK_Teaset</li>
                <li>GL_Teddy</li>
				<!-- Gloomy Deco -->
				<li>GloomyDeco_Board</li>
                <li>GloomyDeco_Kennel</li>
                <li>GloomyDeco_Bucket</li>
                <li>GloomyDeco_Cart</li>
                <li>GloomyDeco_Lumberjack</li>
                <li>GloomyDeco_MailBox</li>
                <li>GloomyDeco_Rope</li>
                <li>GloomyDeco_Boat</li>
                <li>GloomyDeco_Scarecrow</li>
                <li>GloomyDeco_Sign</li>
                <li>GloomyDeco_Stone</li>
                <li>GloomyDeco_Tree</li>
                <li>GloomyDeco_Tool</li>
                <li>GloomyDeco_Well</li>
                <li>GloomyDeco_Windmill</li>
				<li>GloomyDeco_TrashCan</li>
              </defNames>
              <designationCategory>Furniture</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

			<ArchitectSense.DesignationSubCategoryDef>
              <defName>SubCategory_GloomyPebbleFloor</defName>
              <label>Pebble</label>
              <description>Tiny rocks made into a floor</description>
              <defNames>
                <li>PebbleSandstone</li>
                <li>PebbleGranite</li>
				<li>PebbleLimestone</li>
                <li>PebbleSlate</li>
                <li>PebbleMarble</li>
              </defNames>
              <designationCategory>OutdoorFooors</designationCategory>
            </ArchitectSense.DesignationSubCategoryDef>

          </value>
        </li>

		<li Class="PatchOperationAdd">
        <xpath>Defs/ArchitectSense.DesignationSubCategoryDef[defName="SubCategory_WoodFloors"]/defNames</xpath>
            <value>
				<li>RGK_Terrain</li>
				<li>GL_Terrain</li>
            </value>
        </li>

		<li Class="PatchOperationAdd">
        <xpath>Defs/ArchitectSense.DesignationSubCategoryDef[defName="SubCategory_StandartBeds"]/defNames</xpath>
            <value>
				<li>RGK_bedSingle</li>
				<li>RGK_bedSingleB</li>
            </value>
        </li>

		<li Class="PatchOperationAdd">
        <xpath>Defs/ArchitectSense.DesignationSubCategoryDef[defName="SubCategory_DoubleBeds"]/defNames</xpath>
            <value>
				<li>RGK_bedDouble</li>
				<li>RGK_bedDoubleB</li>
				<li>GL_ClassyDoubleBed</li>
            </value>
		</li>

		<li Class="PatchOperationRemove">
          <xpath>Defs/ThingDef[defName="RGK_Street_Lamp"
		  or defName="RGK_Street_Lamp_L"
		  or defName="RGK_Street_Lamp_Seven"
		  or defName="RGK_Street_Lamp_SevenE"
		  or defName="RGK_lamp"
		  or defName="RGK_LampM"
		  or defName="RGK_lampE"
		  or defName="GL_lamp_White"
		  or defName="GL_LampM_White"
		  or defName="GL_lampE_White"
		  or defName="GL_Street_Lamp_L_White"
		  or defName="GL_Street_Lamp_White"
		  or defName="GL_Street_Lamp_Seven_White"
		  or defName="GL_Street_Lamp_SevenE_White"
		  or @Name="WallLightBase"
		  or @Name="WoodFloorBase"
		  or @Name="PebbleBase"]/designatorDropdown</xpath>
		</li>

      </operations>
    </match>
  </Operation>
</Patch>